@inherits LayoutComponentBase
@inject NavigationManager Nav

<div class="container-app">
    <aside class="sidebar">

        <!-- TOP: Brand/Logo -->
        <div class="side-top">
            <a class="brand" href="/dashboard">
                <span class="brand-badge" aria-hidden="true">
                    <!-- simple book icon -->
                    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M6 4.5h10a2.5 2.5 0 0 1 2.5 2.5v12.5a2 2 0 0 0-2-2H6a2.5 2.5 0 0 0-2.5 2V7A2.5 2.5 0 0 1 6 4.5Z"
                              stroke="currentColor" stroke-width="1.8" stroke-linejoin="round" />
                        <path d="M6 4.5v15" stroke="currentColor" stroke-width="1.8" />
                    </svg>
                </span>

                <div>
                    <h1>MoodJournal</h1>
                    <p>Your Journal</p>
                </div>
            </a>
        </div>

        <!-- MIDDLE: Nav -->
        <div class="side-nav">
            <NavMenu />
        </div>

        <!-- BOTTOM: Quick tips (small) -->
        <div class="side-bottom">
            <div class="quick-tips-card">
                <div class="qt-title">Quick Tips</div>
                <div class="qt-text">One entry per day • Track moods • Search & filter</div>
            </div>
        </div>

    </aside>

    <main class="content">
        @Body
    </main>
</div>
