@inject NavigationManager Nav

<div class="nav">
    @NavLink("/dashboard", "Dashboard", "Overview + streaks")
    @NavLink("/calendar", "Calendar", "Pick any date")
    @NavLink("/timeline", "Timeline", "Paginated history")
    @NavLink("/entry", "New / Edit Entry", "Write today")
    @NavLink("/search", "Search & Filter", "Find anything")
    @NavLink("/analytics", "Analytics", "Charts + trends")
    @NavLink("/tags", "Tags & Categories", "Manage labels")
</div>

@code{
    RenderFragment NavLink(string href, string title, string sub) => builder =>
    {
        var isActive = Nav.Uri.EndsWith(href, StringComparison.OrdinalIgnoreCase);

        builder.OpenElement(0, "a");
        builder.AddAttribute(1, "href", href);
        builder.AddAttribute(2, "class", isActive ? "active" : "");
        builder.OpenElement(3, "div");
        builder.AddContent(4, title);
        builder.CloseElement();
        builder.OpenElement(5, "small");
        builder.AddContent(6, sub);
        builder.CloseElement();
        builder.CloseElement();
    };
}
