<div class="card">
    <div class="header" style="margin-bottom:8px;">
        <div class="title">
            <h2 style="font-size:16px;margin:0;">@Title</h2>
            <p style="margin:4px 0 0;">@DateText • @Category</p>
        </div>
        <span class="badge @MoodBadge">@PrimaryMood</span>
    </div>

    <div class="sub">@Preview</div>

    <div class="pills">
        @foreach (var t in Tags.Take(6))
        {
            <span class="pill">@t</span>
        }
        @if (Tags.Count > 6)
        {
            <span class="pill">+@(Tags.Count - 6) more</span>
        }
    </div>

    <div class="divider"></div>

    <div class="actions">
        <button class="btn btn-small" @onclick="OnOpen">Open</button>
        <button class="btn btn-small btn-danger" @onclick="OnDelete">Delete</button>
    </div>
</div>

@code{
    [Parameter] public string Title { get; set; } = "Untitled";
    [Parameter] public string DateText { get; set; } = "—";
    [Parameter] public string Category { get; set; } = "General";
    [Parameter] public string PrimaryMood { get; set; } = "Calm";
    [Parameter] public string Preview { get; set; } = "Preview…";
    [Parameter] public List<string> Tags { get; set; } = new();
    [Parameter] public EventCallback OnOpen { get; set; }
    [Parameter] public EventCallback OnDelete { get; set; }

    string MoodBadge => PrimaryMood switch
    {
        "Happy" or "Excited" or "Relaxed" or "Grateful" or "Confident" => "badge-good",
        "Sad" or "Angry" or "Stressed" or "Lonely" or "Anxious" => "badge-bad",
        _ => "badge-accent"
    };
}
