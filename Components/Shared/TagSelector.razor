<div>
    <div style="display:flex; gap:10px;">
        <input class="input" placeholder="Add custom tag..." @bind="NewTag" />
        <button class="btn" style="width:48px;" @onclick="Add">+</button>
    </div>

    <div style="height:12px;"></div>

    <div class="sub">Quick add:</div>
    <div style="height:8px;"></div>

    <div class="pills">
        @foreach (var t in Quick)
        {
            var active = Tags.Contains(t);
            <button type="button" class="pill @(active ? "active" : "")" @onclick="(()=>Toggle(t))">
                @t
            </button>
        }
    </div>
</div>

@code {
    [Parameter] public List<string> Tags { get; set; } = new();
    [Parameter] public EventCallback<List<string>> TagsChanged { get; set; }

    string NewTag = "";

    List<string> Quick = new()
    {
        "Work","Career","Studies","Family","Friends","Relationships","Health","Fitness","Personal Growth","Self-care","Hobbies","Travel"
    };

    async Task Add()
    {
        if (string.IsNullOrWhiteSpace(NewTag)) return;
        var v = NewTag.Trim();
        if (!Tags.Contains(v)) Tags.Add(v);
        NewTag = "";
        await TagsChanged.InvokeAsync(Tags);
    }

    async Task Toggle(string t)
    {
        if (Tags.Contains(t)) Tags.Remove(t);
        else Tags.Add(t);
        await TagsChanged.InvokeAsync(Tags);
    }
}
