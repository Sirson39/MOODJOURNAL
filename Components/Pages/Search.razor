@page "/search"

<div class="page-hero">
    <div class="hero-title">
        <h1 style="font-size:56px;">Search</h1>
        <p>Find entries by keywords, dates, moods, tags, and categories.</p>
    </div>
</div>

<div class="card" style="max-width:980px; margin:0 auto;">
    <div class="row row-3">
        <div>
            <label class="sub">Search</label>
            <input class="input" placeholder="Title or content..." @bind="Query" @bind:event="oninput" />
        </div>

        <div>
            <label class="sub">Date Range</label>
            <select class="select" @bind="DateRange">
                <option value="30">Last 30 days</option>
                <option value="7">Last 7 days</option>
                <option value="365">This year</option>
            </select>
        </div>

        <div>
            <label class="sub">Mood</label>
            <select class="select" @bind="Mood">
                <option value="">Any</option>
                <option>Positive</option>
                <option>Neutral</option>
                <option>Negative</option>
            </select>
        </div>
    </div>

    <div style="height:12px;"></div>

    <div class="row row-2">
        <div>
            <label class="sub">Tag</label>
            <input class="input" placeholder="e.g., Work" @bind="Tag" />
        </div>
        <div>
            <label class="sub">Category</label>
            <input class="input" placeholder="e.g., Studies" @bind="Category" />
        </div>
    </div>

    <div style="height:14px;"></div>

    <button class="btn btn-primary" @onclick="Apply">
        <span aria-hidden="true">🔎</span> Apply Filters
    </button>

    <div style="height:14px;"></div>

    <div class="sub">@ResultsCount results</div>

    <div style="height:10px;"></div>

    <div class="card chart" style="padding:14px;">
        <div class="empty" style="min-height:160px;">
            <div style="font-weight:750;">No results yet</div>
            <div class="sub">Try writing an entry first.</div>
        </div>
    </div>
</div>

@code {
    string Query = "";
    string Mood = "";
    string Tag = "";
    string Category = "";
    string DateRange = "30";
    int ResultsCount = 0;

    void Apply() => ResultsCount = 0;
}
