@page "/search"

<div class="header">
    <div class="title">
        <h2>Search & Filter</h2>
        <p>Search by title/content and filter by date range, moods, or tags.</p>
    </div>
</div>

<div class="card">
    <div class="row-3 row">
        <div>
            <label>Search (Title/Content)</label>
            <input class="input" @bind="Query" placeholder="e.g., gym, work, stressed…" />
        </div>
        <div>
            <label>From</label>
            <input type="date" class="input" @bind="From" />
        </div>
        <div>
            <label>To</label>
            <input type="date" class="input" @bind="To" />
        </div>
    </div>

    <div class="row-3 row" style="margin-top:12px;">
        <div>
            <label>Mood Category</label>
            <select class="input" @bind="MoodCat">
                <option value="">Any</option>
                <option>Positive</option>
                <option>Neutral</option>
                <option>Negative</option>
            </select>
        </div>
        <div>
            <label>Tag</label>
            <select class="input" @bind="Tag">
                <option value="">Any</option>
                @foreach (var t in Tags) { <option>@t</option> }
            </select>
        </div>
        <div>
            <label>Category</label>
            <select class="input" @bind="Category">
                <option value="">Any</option>
                @foreach (var c in Categories) { <option>@c</option> }
            </select>
        </div>
    </div>

    <div class="divider"></div>

    <div class="actions">
        <button class="btn btn-primary" @onclick="DoSearch">Search</button>
        <button class="btn" @onclick="Reset">Reset</button>
        <span class="badge">Results: @Results.Count</span>
    </div>
</div>

@foreach (var r in Results)
{
    <div class="card">
        <div class="header" style="margin-bottom:8px;">
            <div class="title">
                <h2 style="font-size:16px;margin:0;">@r.Title</h2>
                <p style="margin:4px 0 0;">@r.Date • @r.Category</p>
            </div>
            <span class="badge badge-accent">@r.Mood</span>
        </div>
        <div class="sub">@r.Snippet</div>
    </div>
}

@code{
    string Query = "";
    string From = DateTime.Today.AddDays(-30).ToString("yyyy-MM-dd");
    string To = DateTime.Today.ToString("yyyy-MM-dd");
    string MoodCat = "";
    string Tag = "";
    string Category = "";

    List<string> Tags = new(){ "Work","Health","Fitness","Travel","Reflection","Projects" };
    List<string> Categories = new(){ "Personal","Work","Health","Study","Travel","Projects","Reflection" };

    List<Result> Results = new();

    void DoSearch()
    {
        // demo results
        Results = new()
        {
            new("2025-12-20","A calm productive day","Work","Calm","Found by search filters (demo)…"),
            new("2025-12-19","Gym + self-care","Health","Confident","Preview snippet (demo)…")
        };
    }

    void Reset()
    {
        Query=""; MoodCat=""; Tag=""; Category="";
        Results.Clear();
    }

    record Result(string Date,string Title,string Category,string Mood,string Snippet);
}
