@page "/calendar"

<div class="page-hero">
    <div class="hero-title">
        <h1 style="font-size:52px;">Calendar</h1>
        <p>Navigate through your journal history</p>
    </div>
</div>

<div class="calendar" style="max-width:980px; margin:0 auto;">
    <div class="cal-top">
        <div>
            <h2>@MonthTitle</h2>
        </div>
        <div class="cal-nav">
            <button class="cal-btn" @onclick="PrevMonth">‹</button>
            <button class="btn" style="padding:9px 12px;" @onclick="GoToday">Today</button>
            <button class="cal-btn" @onclick="NextMonth">›</button>
        </div>
    </div>

    <div class="cal-days">
        @foreach (var d in DayNames)
        {
            <div class="cal-head">@d</div>
        }

        @foreach (var cell in Cells)
        {
            <div class="cal-cell @cell.Class" @onclick="(()=>Select(cell.Date))">@cell.Day</div>
        }
    </div>

    <div style="height:18px;"></div>

    <div class="sub" style="text-align:center;">
        <span style="display:inline-flex; gap:10px; align-items:center; justify-content:center;">
            <span class="badge good">● Positive</span>
            <span class="badge neutral">● Neutral</span>
            <span class="badge bad">● Negative</span>
        </span>
    </div>
</div>

@code {
    DateTime Current = new(DateTime.Now.Year, DateTime.Now.Month, 1);
    DateTime Selected = DateTime.Now.Date;

    string MonthTitle => Current.ToString("MMMM yyyy");
    string[] DayNames => new[] { "Sun", "Mon", "Tue", "Wed", "Thu", "Fri", "Sat" };

    List<CalCell> Cells => BuildCells();

    void PrevMonth() => Current = Current.AddMonths(-1);
    void NextMonth() => Current = Current.AddMonths(1);
    void GoToday()
    {
        Current = new DateTime(DateTime.Now.Year, DateTime.Now.Month, 1);
        Selected = DateTime.Now.Date;
    }

    void Select(DateTime date) => Selected = date.Date;

    List<CalCell> BuildCells()
    {
        var list = new List<CalCell>();
        var start = Current;
        var firstDayOfGrid = start.AddDays(-(int)start.DayOfWeek);
        for (int i = 0; i < 42; i++)
        {
            var d = firstDayOfGrid.AddDays(i);
            var cls = "";
            if (d.Month != Current.Month) cls = "muted";
            if (d.Date == DateTime.Now.Date) cls += " today";
            if (d.Date == Selected.Date) cls += " selected";
            list.Add(new CalCell { Date = d, Day = d.Day.ToString(), Class = cls.Trim() });
        }
        return list;
    }

    class CalCell
    {
        public DateTime Date { get; set; }
        public string Day { get; set; } = "";
        public string Class { get; set; } = "";
    }
}
