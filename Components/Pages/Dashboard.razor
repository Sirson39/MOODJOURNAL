@page "/dashboard"
@inject NavigationManager Nav

<div class="page-hero">
    <div class="hero-title">
        <h1>Welcome back</h1>
        <p>@TodayText</p>
    </div>

    <div class="actions">
        <button class="btn btn-primary" @onclick="(()=>Nav.NavigateTo(" /entry"))">
            <span aria-hidden="true">✍</span>
            Write Today
        </button>
    </div>
</div>

<div class="grid grid-3">
    <div class="card">
        <h3>Your Journey</h3>
        <div class="sub">Streaks, entries, and missed days.</div>
        <div class="divider"></div>

        <div class="grid grid-2">
            <div class="card" style="background: linear-gradient(135deg, var(--primary), var(--primary-2)); color:#fff; border-color: rgba(255,255,255,.18)">
                <div class="kpi">
                    <div class="kpi-ico" style="background: rgba(255,255,255,.18); border-color: rgba(255,255,255,.22); color:#fff;">
                        <span>🔥</span>
                    </div>
                    <div class="kpi-meta">
                        <b>Current Streak</b>
                        <small>@CurrentStreak days</small>
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="kpi">
                    <div class="kpi-ico"><span>🏆</span></div>
                    <div class="kpi-meta">
                        <b>Best Streak</b>
                        <small>@BestStreak days</small>
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="kpi">
                    <div class="kpi-ico"><span>📖</span></div>
                    <div class="kpi-meta">
                        <b>Total Entries</b>
                        <small>@TotalEntries journals</small>
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="kpi">
                    <div class="kpi-ico"><span>🗓</span></div>
                    <div class="kpi-meta">
                        <b>Missed (30d)</b>
                        <small>@MissedDays days</small>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card chart">
        <h3>Mood Distribution</h3>
        <div class="divider"></div>
        <div class="empty">
            <div class="ico">😐</div>
            <div>
                <div style="font-weight:700;">No mood data yet</div>
                <div class="sub">Start journaling to see your mood trends</div>
            </div>
        </div>
    </div>

    <div class="card chart">
        <h3>Popular Tags</h3>
        <div class="divider"></div>
        <div class="empty">
            <div class="ico">🏷</div>
            <div>
                <div style="font-weight:700;">No tags yet</div>
                <div class="sub">Add tags to your entries to see them here</div>
            </div>
        </div>
    </div>
</div>

<div style="height:16px;"></div>

<div class="grid grid-2">
    <div class="card chart">
        <div style="display:flex; align-items:center; justify-content:space-between; gap:10px;">
            <h3 style="margin:0;">Word Count Trends</h3>
            <div class="sub"><span style="color:var(--primary); font-weight:800;">↗</span> Avg: @AvgWords words</div>
        </div>
        <div class="divider"></div>
        <div class="empty" style="min-height:160px;">
            <div class="sub">No words yet — write your first entry.</div>
        </div>
    </div>

    <div class="card chart">
        <div style="display:flex; align-items:center; justify-content:space-between; gap:10px;">
            <h3 style="margin:0;">Recent Entries</h3>
            <a href="/timeline" class="sub" style="color:var(--primary); font-weight:700;">View all ›</a>
        </div>
        <div class="divider"></div>
        <div class="empty" style="min-height:160px;">
            <div style="font-weight:750;">No entries yet</div>
            <a class="sub" href="/entry" style="color:var(--primary); font-weight:800;">Write your first entry →</a>
        </div>
    </div>
</div>

@code {
    string TodayText => DateTime.Now.ToString("dddd, MMMM d, yyyy");
    int CurrentStreak = 0;
    int BestStreak = 0;
    int TotalEntries = 0;
    int MissedDays = 0;
    int AvgWords = 0;
}
