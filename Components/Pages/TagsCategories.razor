@page "/tags"

<div class="page-hero">
    <div class="hero-title">
        <h1 style="font-size:56px;">Tags</h1>
        <p>Manage the labels you use to organize and filter your journal.</p>
    </div>
</div>

<div class="grid grid-2" style="max-width:980px; margin:0 auto;">
    <div class="card">
        <h3>Tags</h3>
        <div class="sub">Create, remove, and quickly add tags to entries.</div>
        <div class="divider"></div>

        <div style="display:flex; gap:10px;">
            <input class="input" placeholder="Add new tag..." @bind="NewTag" />
            <button class="btn btn-primary" @onclick="AddTag">+</button>
        </div>

        <div style="height:12px;"></div>

        <div class="pills">
            @foreach (var t in Tags)
            {
                <span class="pill active">
                    🏷 @t
                    <button class="btn btn-ghost" style="padding:6px 10px;" @onclick="(()=>RemoveTag(t))">×</button>
                </span>
            }
        </div>
    </div>

    <div class="card">
        <h3>Categories</h3>
        <div class="sub">Group entries under a category for cleaner filtering.</div>
        <div class="divider"></div>

        <div style="display:flex; gap:10px;">
            <input class="input" placeholder="Add new category..." @bind="NewCategory" />
            <button class="btn btn-primary" @onclick="AddCategory">+</button>
        </div>

        <div style="height:12px;"></div>

        <div class="pills">
            @foreach (var c in Categories)
            {
                <span class="pill">
                    📌 @c
                    <button class="btn btn-ghost" style="padding:6px 10px;" @onclick="(()=>RemoveCategory(c))">×</button>
                </span>
            }
        </div>
    </div>
</div>

@code {
    string NewTag = "";
    string NewCategory = "";

    List<string> Tags = new() { "Work", "Studies", "Health", "Friends", "Fitness", "Personal Growth", "Travel" };
    List<string> Categories = new() { "Work", "Studies", "Health", "Family" };

    void AddTag()
    {
        if (!string.IsNullOrWhiteSpace(NewTag))
        {
            Tags.Add(NewTag.Trim());
            NewTag = "";
        }
    }

    void RemoveTag(string t) => Tags.Remove(t);

    void AddCategory()
    {
        if (!string.IsNullOrWhiteSpace(NewCategory))
        {
            Categories.Add(NewCategory.Trim());
            NewCategory = "";
        }
    }

    void RemoveCategory(string c) => Categories.Remove(c);
}
