@page "/analytics"

<div class="page-hero">
    <div class="hero-title">
        <h1 style="font-size:56px;">Analytics</h1>
        <p>Insights into your journaling patterns</p>
    </div>

    <div class="actions">
        <select class="select" style="width:170px;">
            <option>Last 30 days</option>
            <option>Last 7 days</option>
            <option>This year</option>
        </select>
    </div>
</div>

<div class="grid grid-3" style="grid-template-columns:repeat(4, 1fr);">
    <div class="card">
        <div class="kpi">
            <div class="kpi-ico"><span>📄</span></div>
            <div class="kpi-meta">
                <b>Total Entries</b>
                <small>0</small>
            </div>
        </div>
    </div>
    <div class="card">
        <div class="kpi">
            <div class="kpi-ico"><span>🔥</span></div>
            <div class="kpi-meta">
                <b>Current Streak</b>
                <small>0 days</small>
            </div>
        </div>
    </div>
    <div class="card">
        <div class="kpi">
            <div class="kpi-ico"><span>📈</span></div>
            <div class="kpi-meta">
                <b>Avg. Words</b>
                <small>0</small>
            </div>
        </div>
    </div>
    <div class="card">
        <div class="kpi">
            <div class="kpi-ico"><span>🗓</span></div>
            <div class="kpi-meta">
                <b>Missed Days</b>
                <small>30</small>
            </div>
        </div>
    </div>
</div>

<div style="height:16px;"></div>

<div class="grid grid-2">
    <div class="card chart">
        <div style="display:flex;align-items:center;gap:10px;">
            <div class="kpi-ico" style="width:42px;height:42px;"><span>🙂</span></div>
            <div>
                <h3 style="margin:0;">Mood Distribution</h3>
                <div class="sub">No entries in this period</div>
            </div>
        </div>
        <div class="divider"></div>
        <div class="empty" style="min-height:240px;">
            <div class="sub">No entries in this period</div>
        </div>
    </div>

    <div class="card chart">
        <div style="display:flex;align-items:center;gap:10px;">
            <div class="kpi-ico" style="width:42px;height:42px;"><span>📈</span></div>
            <div>
                <h3 style="margin:0;">Word Count Trend</h3>
                <div class="sub">Total: 0 words</div>
            </div>
        </div>
        <div class="divider"></div>
        <div class="empty" style="min-height:240px;">
            <div class="sub">No data yet</div>
        </div>
    </div>
</div>

<div style="height:16px;"></div>

<div class="grid grid-2">
    <div class="card chart">
        <h3>Most Used Tags</h3>
        <div class="divider"></div>
        <div class="empty" style="min-height:220px;">
            <div class="sub">No tags used yet</div>
        </div>
    </div>

    <div class="card chart">
        <h3>Mood Timeline</h3>
        <div class="divider"></div>
        <div class="empty" style="min-height:220px;">
            <div class="sub">No mood history yet</div>
        </div>
    </div>
</div>

<div style="height:16px;"></div>

<div class="card chart">
    <h3>Streak Statistics</h3>
    <div class="divider"></div>
    <div class="grid grid-3" style="grid-template-columns:repeat(3, 1fr);">
        <div class="card" style="background:rgba(217,119,6,.08);">
            <div style="text-align:center;">
                <div style="font-size:46px; font-weight:800; color:rgba(42,31,20,.55);">0</div>
                <div class="sub">Current Streak</div>
            </div>
        </div>
        <div class="card" style="background:rgba(217,119,6,.06);">
            <div style="text-align:center;">
                <div style="font-size:46px; font-weight:800; color:rgba(42,31,20,.45);">0</div>
                <div class="sub">Longest Streak</div>
            </div>
        </div>
        <div class="card" style="background:rgba(217,119,6,.06);">
            <div style="text-align:center;">
                <div style="font-size:46px; font-weight:800; color:rgba(42,31,20,.55);">30</div>
                <div class="sub">Missed Days (Last 30 days)</div>
            </div>
        </div>
    </div>
</div>
