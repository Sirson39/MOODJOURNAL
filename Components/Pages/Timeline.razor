@page "/timeline"

<div class="page-hero">
    <div class="hero-title">
        <h1 style="font-size:64px;">Timeline</h1>
        <p>Browse and search all your entries</p>
    </div>
</div>

<div class="card" style="max-width:980px; margin:0 auto;">
    <div style="display:flex; gap:12px; align-items:center;">
        <input class="input" placeholder="Search entries..." @bind="Query" @bind:event="oninput" />
        <button class="btn" @onclick="ToggleFilters">
            <span aria-hidden="true">⏷</span>
            Filters
        </button>
    </div>

    @if (ShowFilters)
    {
        <div style="height:12px;"></div>
        <div class="row row-3">
            <div>
                <label class="sub">Mood</label>
                <select class="select" @bind="Mood">
                    <option value="">Any</option>
                    <option>Positive</option>
                    <option>Neutral</option>
                    <option>Negative</option>
                </select>
            </div>
            <div>
                <label class="sub">Tag</label>
                <input class="input" placeholder="e.g., Work" @bind="Tag" />
            </div>
            <div>
                <label class="sub">Category</label>
                <input class="input" placeholder="e.g., Studies" @bind="Category" />
            </div>
        </div>
    }

    <div style="height:14px;"></div>
    <div class="sub">@EntriesFound entries found</div>

    <div style="height:10px;"></div>

    <div class="card chart" style="padding:14px;">
        <div class="empty" style="min-height:160px;">
            <div style="font-weight:750;">No entries found</div>
        </div>
    </div>
</div>

@code {
    string Query = "";
    string Mood = "";
    string Tag = "";
    string Category = "";
    bool ShowFilters = false;

    int EntriesFound => 0;

    void ToggleFilters() => ShowFilters = !ShowFilters;
}
