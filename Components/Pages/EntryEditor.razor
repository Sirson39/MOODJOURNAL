@page "/entry"
@inject NavigationManager Nav

<div class="entry-shell">
    <div class="page-hero" style="justify-content:center; position:relative; margin-bottom: 8px;">
        <div style="flex:1;"></div>

        <div style="flex:2;">
            <h1 class="entry-title">New Entry</h1>
            <div class="entry-meta">
                <span class="pill-date">
                    <span aria-hidden="true">📅</span>
                    @DateText
                </span>
            </div>
        </div>

        <div class="actions" style="flex:1; justify-content:flex-end;">
            <button class="btn btn-primary" @onclick="Save">
                <span aria-hidden="true">💾</span>
                Save Entry
            </button>
        </div>
    </div>

    <div class="card" style="margin-top:10px;">
        <input class="input" placeholder="Give your entry a title..." @bind="Title" />
    </div>

    <div style="height:14px;"></div>

    <div class="editor">
        <textarea class="textarea" placeholder="Start writing your thoughts..." @bind="Content" @bind:event="oninput"></textarea>
        <div class="word-count">@WordCount words</div>
    </div>

    <div style="height:14px;"></div>

    <div class="card">
        <h3>Primary Mood <span style="color:var(--bad);">*</span></h3>
        <div class="sub">Choose one mood that best describes your day.</div>
        <div class="divider"></div>
        <MoodPicker PrimaryMood="@PrimaryMood" PrimaryMoodChanged="OnPrimaryMoodChanged"
                    SecondaryMoods="@SecondaryMoods" SecondaryMoodsChanged="OnSecondaryChanged" />
    </div>

    <div style="height:14px;"></div>

    <div class="card">
        <h3>Tags (optional)</h3>
        <div class="sub">Add custom tags and quickly reuse common ones.</div>
        <div class="divider"></div>
        <TagSelector Tags="@Tags" TagsChanged="OnTagsChanged" />
    </div>

    <div style="height:14px;"></div>

    <div class="card">
        <h3>Category (optional)</h3>
        <div class="sub">Keep entries organized by category.</div>
        <div class="divider"></div>
        <select class="select" @bind="Category">
            <option value="">Select a category…</option>
            @foreach (var c in Categories)
            {
                <option value="@c">@c</option>
            }
        </select>
    </div>

    <div style="height:24px;"></div>
</div>

@code {
    string DateText => DateTime.Now.ToString("dddd, MMMM d, yyyy");

    string Title = "";
    string Content = "";

    string PrimaryMood = "Happy";
    List<string> SecondaryMoods = new();
    List<string> Tags = new();
    string Category = "";

    List<string> Categories = new() { "Work", "Health", "Studies", "Family", "Friends", "Personal Growth", "Travel" };

    int WordCount => string.IsNullOrWhiteSpace(Content)
        ? 0
        : Content.Split(' ', StringSplitOptions.RemoveEmptyEntries).Length;

    void Save()
    {
        Nav.NavigateTo("/dashboard");
    }

    void OnPrimaryMoodChanged(string value) => PrimaryMood = value;
    void OnSecondaryChanged(List<string> list) => SecondaryMoods = list;
    void OnTagsChanged(List<string> list) => Tags = list;
}
