@page "/"
@inject NavigationManager Nav

<div class="auth">
    <div class="card">
        <div class="header">
            <div class="title">
                <h2>Unlock MoodJournal</h2>
                <p>Enter PIN/password to access your private entries.</p>
            </div>
            <span class="badge badge-accent">Local • Private</span>
        </div>

        <label>PIN / Password</label>
        <input type="password" class="input" @bind="Pin" placeholder="Demo PIN: 1234" />

        <div class="actions" style="margin-top:12px;">
            <button class="btn btn-primary" @onclick="Unlock">Unlock</button>
            <button class="btn" @onclick="Reset" type="button">Clear</button>
        </div>

        @if (!string.IsNullOrWhiteSpace(Error))
        {
            <div class="divider"></div>
            <span class="badge badge-bad">@Error</span>
        }

        <div class="divider"></div>
        <div class="sub">
            Milestone mode: PIN = <b>1234</b>. You can implement real security later in Settings.
        </div>
    </div>
</div>

@code{
    string Pin = "";
    string Error = "";

    void Unlock()
    {
        if (Pin == "1234")
        {
            Nav.NavigateTo("/dashboard");
            return;
        }
        Error = "Incorrect PIN. Try demo PIN: 1234";
    }

    void Reset()
    {
        Pin = "";
        Error = "";
    }
}
